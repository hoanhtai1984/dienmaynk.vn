DATABASE_URL="mysql://root:@localhost:3306/dienmaynk"
PORT=4000
JWT_SECRET="change-me"
ADMIN_EMAIL="admin@dienmaynk.vn"
ADMIN_PASSWORD="change-me"
CLIENT_URL="http://localhost:5173"

# Gửi email đặt lại mật khẩu cho khách hàng. Bỏ trống khi dev - link đặt lại
# mật khẩu sẽ được in ra console server thay vì gửi email thật.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Điện Máy NK <no-reply@dienmaynk.vn>"

# Theo dõi lỗi tập trung (Sentry). Bỏ trống khi dev - lỗi vẫn được log đầy đủ
# ra console, chỉ là không có ai được báo tự động. Để bật: tạo tài khoản
# miễn phí tại sentry.io, tạo project Node.js, dán DSN được cấp vào đây.
SENTRY_DSN=""

# Đăng nhập khách hàng qua Google/Facebook. Google: tạo OAuth Client ID (loại
# "Web application") tại console.cloud.google.com -> APIs & Services ->
# Credentials. Facebook: tạo app tại developers.facebook.com, bật sản phẩm
# "Facebook Login". Client ID/App ID trùng với VITE_GOOGLE_CLIENT_ID/
# VITE_FACEBOOK_APP_ID phía client/.env - App Secret thì chỉ để ở đây, không
# bao giờ đưa lên client.
GOOGLE_CLIENT_ID=""
FACEBOOK_APP_ID=""
FACEBOOK_APP_SECRET=""
