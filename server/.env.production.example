DATABASE_URL="mysql://<user>:<password>@<host>:3306/<database>"
PORT=4000
JWT_SECRET="<random-long-secret-generate-your-own>"
ADMIN_EMAIL="admin@dienmaynk.vn"
ADMIN_PASSWORD="<strong-password-change-me>"
CLIENT_URL="https://your-frontend-domain.com"

# Bắt buộc để "Quên mật khẩu" gửi được email thật (không có thì link chỉ in
# ra log server, khách hàng không nhận được).
SMTP_HOST="<smtp-host-cua-nha-cung-cap-email>"
SMTP_PORT="587"
SMTP_USER="<smtp-username>"
SMTP_PASS="<smtp-password-or-api-key>"
MAIL_FROM="Điện Máy NK <no-reply@dienmaynk.vn>"

# Khuyến nghị mạnh cho production - không có thì lỗi ngầm (vd: crash lúc
# 2h sáng) sẽ không ai biết cho tới khi khách phàn nàn. Tạo tài khoản miễn
# phí tại sentry.io -> tạo project Node.js -> dán DSN được cấp vào đây.
SENTRY_DSN="<dsn-lay-tu-sentry.io>"

# Đăng nhập khách hàng qua Google/Facebook - dùng OAuth app THẬT của production
# (domain callback phải trỏ đúng domain production, không phải localhost).
GOOGLE_CLIENT_ID="<google-oauth-client-id-production>"
FACEBOOK_APP_ID="<facebook-app-id-production>"
FACEBOOK_APP_SECRET="<facebook-app-secret-production>"
