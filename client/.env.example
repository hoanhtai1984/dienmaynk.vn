VITE_API_URL=http://localhost:4000
VITE_AI_SERVICE_URL=http://localhost:8000

# Đăng nhập khách hàng qua Google/Facebook - đây là ID công khai (an toàn để
# lộ trong bundle client), khác với App Secret ở server/.env không bao giờ
# đưa lên đây. Client ID/App ID phải TRÙNG với server/.env.
VITE_GOOGLE_CLIENT_ID=
VITE_FACEBOOK_APP_ID=
